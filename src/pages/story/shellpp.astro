---
import "../../styles/global.css";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path: string) => `${basePath}${path.replace(/^\/+/, "")}`;

const storySections = [
  {
    id: "watch-workflow",
    label: "01",
    title: "从手环端完成操作",
    body: [
      "Shell++ 的核心功能运行在手环内部。通过 QuickApp 界面发起操作，由 Lua 后端调用设备能力、执行任务并返回结果。",
      "应用管理、文件查看、设备测试、资源占用监控等功能，都可以直接在手环端完成，不必频繁连接调试环境，也不需要反复输入命令。",
    ],
  },
  {
    id: "performance",
    label: "02",
    title: "实时查看设备性能状态",
    body: [
      "Shell++ 不只是展示静态设备信息，还可以观察设备实际运行时的状态。应用内提供 CPU 与内存占用查看功能，可以直观了解当前系统负载、剩余资源以及不同操作对设备性能的影响。",
      "在探索 Lua 系统能力的过程中，我们还加入了悬浮 CPU 与内存监控。性能信息可以显示在其他应用界面上，方便用户实时观察应用启动、页面切换和功能运行时的资源变化。",
      "对于普通用户，它是一块直观的设备状态面板。对于开发者，它则是一套性能分析工具。",
    ],
  },
  {
    id: "unified-control",
    label: "03",
    title: "应用、文件与设备能力统一管理",
    body: [
      "Shell++ 将多个原本分散的设备功能集中到同一个入口。用户可以管理设备上的应用，也可以浏览文件目录、确认资源文件和检查程序生成的数据。",
      "设备性能测试功能则可以帮助用户了解硬件的实际运行表现，为应用开发、性能优化和设备对比提供参考。",
    ],
  },
  {
    id: "cross-platform",
    label: "04",
    title: "Android、iOS 与 PC 都能使用",
    body: [
      "多端支持是 Shell++ 的重要组成部分。手环产生的文件和数据不应该只能停留在某一种手机系统中，也不应要求用户必须准备特定设备。",
      "Android 用户可以通过专用同步器与手环连接，快速接收和管理数据。iOS、Windows、macOS 和 Linux 用户，则可以通过 AstroBox 插件完成数据传输。",
      "无论使用 Android、iOS 还是 PC，都可以选择适合自己的同步方式。这种设计降低了平台限制，也让 Shell++ 更适合开发者、普通用户以及同时使用多种设备的人群。",
    ],
  },
  {
    id: "beyond-screenshot",
    label: "05",
    title: "截图只是其中一个功能",
    body: [
      "Shell++ 最初解决的问题，是传统手环截图方案需要频繁拉取日志，操作步骤过于繁琐。现在，设备可以在手环端完成截图处理，并通过 Interconnect 将文件传输到接收端。",
      "但截图并不是 Shell++ 的全部。随着项目不断发展，Shell++ 已经从单一功能扩展为包含应用管理、文件查看、性能测试、CPU 与内存监控、多端同步的综合设备工具。",
      "截图是起点，而不是终点。",
    ],
  },
  {
    id: "experience",
    label: "06",
    title: "好看、好用、强大同步推进",
    body: [
      "对于手环应用而言，功能数量并不代表实际体验。好看，决定用户是否愿意打开。有限的屏幕空间要求界面足够清晰，信息层级足够明确，常用功能能够快速找到。",
      "好用，决定用户是否愿意长期使用。设备管理不应依赖复杂命令，性能查看不应必须连接电脑，文件传输也不应被平台限制。",
      "强大，决定应用能够解决多少实际问题。从系统状态查看到文件管理，从设备测试到多端同步，Shell++ 正在不断降低玩环的门槛。三者并行，才能让 Shell++ 不只是一个功能实验，而是一款真正适合长期安装和使用的 Vela QuickApp。",
    ],
  },
  {
    id: "safety",
    label: "07",
    title: "安全机制",
    body: [
      "我们清楚，Shell++ 的高可玩性一旦被滥用，可能对设备造成不可逆损害。因此，我们设计了 IPC 保护机制。",
      "我们通过使用多台设备测试，归纳高风险指令，将可能破坏系统、删除关键文件或导致设备异常的操作纳入拦截范围，在保留扩展能力的同时，尽可能减少“变砖”的概率。",
    ],
  },
  {
    id: "future",
    label: "08",
    title: "名为 Shell，更是 Plus Plus",
    body: [
      "Shell 是我们理解设备的起点，两个加号则代表持续生长。从简化一次截图开始，到建立完整的手环工作链路，再到应用管理、文件查看、性能测试、Lua 探索与悬浮监控，Shell++ 的每一步都来自实际使用中的问题。",
      "它不是一开始就被规划成庞大的工具集合，而是在一次次需求、实验和改进中，逐渐找到自己的形态。",
      "未来，Shell++ 仍会沿着同一个方向继续前进：让复杂能力更容易抵达，让设备数据更自由地流动，让手环从一个只能被动展示信息的终端，变成一个可以被理解、被探索、被充分使用的设备。",
      "现有功能会继续优化，新的系统能力也会随着 Lua 与 Vela 环境的深入探索不断加入。",
    ],
  },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Shell++ 长文章页：从截图需求出发，讲清楚这套面向 Xiaomi Vela 设备的工具链如何演进为集设备管理、性能监控与多端同步于一体的 QuickApp。"
    />
    <title>Shell++ 文章 | “解锁”手环的高级玩法</title>
    <link
      id="site-favicon"
      rel="icon"
      type="image/png"
      href={withBase("assets/brand-icon-light.png")}
      data-light-href={withBase("assets/brand-icon-light.png")}
      data-dark-href={withBase("assets/brand-icon-dark.png")}
    />
  </head>
  <body>
    <div class="app-shell longform-page">
      <header class="topbar">
        <a class="brand-lockup" href={basePath} aria-label="Shell++">
          <img
            class="brand-mark"
            id="brand-mark"
            src={withBase("assets/brand-icon-light.png")}
            data-light-src={withBase("assets/brand-icon-light.png")}
            data-dark-src={withBase("assets/brand-icon-dark.png")}
            alt="Shell++ 图标"
          />
          <span>Shell++</span>
        </a>
        <nav class="topnav" aria-label="文章页导航">
          <a href={withBase("")}>首页</a>
          <a href="#top">开头</a>
          <a href="#article-body">正文</a>
          <a href="#article-end">结尾</a>
        </nav>
        <a
          class="icon-button github-link"
          href="https://github.com/Shellplusplus/Shellplusplus/releases/latest"
          target="_blank"
          rel="noreferrer"
          aria-label="打开最新版本发布页"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="github-mark">
            <path
              d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.9-.64.07-.63.07-.63 1 .07 1.52 1.05 1.52 1.05.88 1.56 2.32 1.11 2.89.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.15-4.55-5.11 0-1.13.39-2.06 1.03-2.79-.1-.26-.45-1.31.1-2.74 0 0 .84-.28 2.75 1.07A9.3 9.3 0 0 1 12 6.8c.85 0 1.7.12 2.49.36 1.9-1.35 2.74-1.07 2.74-1.07.55 1.43.21 2.48.11 2.74.64.73 1.03 1.66 1.03 2.79 0 3.97-2.34 4.84-4.57 5.1.36.32.68.95.68 1.92 0 1.39-.01 2.51-.01 2.85 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"
            />
          </svg>
        </a>
        <button class="icon-button" id="theme-toggle" type="button" aria-label="切换主题" aria-pressed="false">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3v2.5M12 18.5V21M5.64 5.64l1.77 1.77M16.59 16.59l1.77 1.77M3 12h2.5M18.5 12H21M5.64 18.36l1.77-1.77M16.59 7.41l1.77-1.77M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" />
          </svg>
        </button>
      </header>

      <main class="longform-main">
        <section class="longform-hero" id="top">
          <div class="longform-hero-inner">
            <p class="longform-kicker">Shell++ Story</p>
            <h1>“解锁”手环的高级玩法</h1>
            <p class="longform-dek">
              一切开始于一个看似简单的需求：怎样更轻松地拿到手环截图？Shell++ 由此向外生长，
              逐步把设备管理、文件浏览、性能监控、功能测试与多端同步整合进同一个工作流。
            </p>
            <div class="longform-meta">
              <span>Shell++ 团队</span>
              <span>Vela QuickApp / Lua / 多端同步</span>
              <span>长文阅读</span>
            </div>
          </div>
        </section>

        <section class="longform-shell">
          <aside class="longform-sidebar">
            <div class="longform-sidebar-card">
              <span class="label">导读</span>
              <p>
                智能穿戴设备的能力正在不断增强，但许多实用功能仍然被限制在设备内部。文件难以导出，运行状态不够直观，设备管理依赖调试工具，不同平台之间的数据传输也缺少统一方案。Shell++ 正是为了解决这些问题而诞生。
              </p>
            </div>
            <nav class="longform-toc" aria-label="目录">
              <span class="label">目录</span>
              {storySections.map((section) => (
                <a href={`#${section.id}`}>
                  <em>{section.label}</em>
                  <span>{section.title}</span>
                </a>
              ))}
            </nav>
          </aside>

          <article class="longform-article" id="article-body">
            <div class="longform-prose">
              <p>
                Shell++ 采用 Vela QuickApp 前端、Lua 后端相结合的架构，将设备管理、文件浏览、性能监控、
                功能测试和多端同步整合在同一个应用中。
              </p>

              {storySections.map((section) => (
                <section class="longform-section" id={section.id}>
                  <div class="longform-section-anchor">{section.label}</div>
                  <h2>{section.title}</h2>
                  {section.body.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </section>
              ))}

              <blockquote class="longform-quote">
                <p>截图是起点，而不是终点。</p>
              </blockquote>

              <p>
                从简化一次截图开始，到建立完整的手环工作链路，再到应用管理、文件查看、性能测试、
                Lua 探索与悬浮监控，Shell++ 的每一步都来自实际使用中的问题。它不是一开始就被规划成庞大的工具集合，
                而是在一次次需求、实验和改进中，逐渐找到自己的形态。
              </p>

              <p>
                未来，Shell++ 仍会沿着同一个方向继续前进：让复杂能力更容易抵达，让设备数据更自由地流动，
                让手环从一个只能被动展示信息的终端，变成一个可以被理解、被探索、被充分使用的设备。
              </p>

              <p class="longform-signoff">Shell++ 团队呈上</p>
            </div>
          </article>
        </section>

        <section class="longform-end" id="article-end">
          <div class="longform-end-inner">
            <p class="label">Next</p>
            <h2>继续看，或者直接下载</h2>
            <p>
              如果你是来了解项目，可以把这篇文章直接分享出去。如果你已经准备上手，继续去下载页拿最新构建就行。
            </p>
            <div class="longform-end-actions">
              <a class="line-action" href={basePath}>返回首页</a>
              <a class="primary-action" href={withBase("download/")}>前往下载</a>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <p>Shell++</p>
        <p>Long-form article page for the Shell++ workflow story.</p>
        <p id="footer-year">© 2026 Shell++</p>
      </footer>
    </div>

    <script is:inline src={withBase("scripts/reveal.js")}></script>
    <script is:inline src={withBase("scripts/cursor-glint.js")}></script>
    <script is:inline src={withBase("scripts/anchor-focus.js")}></script>
    <script is:inline src={withBase("scripts/external-link-dialog.js")}></script>
    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.getElementById("theme-toggle");
      const footerYear = document.getElementById("footer-year");
      const brandMark = document.getElementById("brand-mark");
      const siteFavicon = document.getElementById("site-favicon");
      const storedTheme = window.localStorage.getItem("shellpp-site-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
      let isThemeTransitioning = false;

      function applyTheme(theme) {
        const isDark = theme === "dark";
        if (isDark) {
          root.dataset.theme = "dark";
        } else {
          delete root.dataset.theme;
        }
        themeToggle?.setAttribute("aria-pressed", isDark ? "true" : "false");

        if (brandMark) {
          brandMark.src = isDark ? brandMark.dataset.darkSrc : brandMark.dataset.lightSrc;
        }

        if (siteFavicon) {
          siteFavicon.href = isDark ? siteFavicon.dataset.darkHref : siteFavicon.dataset.lightHref;
        }
      }

      const initialTheme = storedTheme || (prefersDark.matches ? "dark" : "light");
      applyTheme(initialTheme);

      function setStoredTheme(theme) {
        applyTheme(theme);
        window.localStorage.setItem("shellpp-site-theme", theme);
      }

      function cleanupThemeTransition(scrollX, scrollY) {
        window.scrollTo(scrollX, scrollY);
        root.classList.remove("is-theme-transitioning");
        isThemeTransitioning = false;
      }

      function animateThemeTransition() {
        try {
          document.documentElement.animate(
            {
              opacity: [0, 1],
              filter: ["blur(8px)", "blur(0px)"],
            },
            {
              duration: 320,
              easing: "cubic-bezier(0.22, 0.74, 0.18, 1)",
              fill: "both",
              pseudoElement: "::view-transition-new(root)",
            },
          );

          document.documentElement.animate(
            {
              opacity: [1, 0],
            },
            {
              duration: 220,
              easing: "ease-out",
              fill: "both",
              pseudoElement: "::view-transition-old(root)",
            },
          );
        } catch {
          // If pseudo-element animations are unsupported, keep the transition functional without extra effects.
        }
      }

      themeToggle?.addEventListener("click", () => {
        if (isThemeTransitioning) {
          return;
        }

        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (!document.startViewTransition || reduceMotion) {
          setStoredTheme(nextTheme);
          return;
        }

        const scrollX = window.scrollX;
        const scrollY = window.scrollY;
        isThemeTransitioning = true;
        root.classList.add("is-theme-transitioning");

        try {
          const transition = document.startViewTransition(() => {
            setStoredTheme(nextTheme);
          });

          transition.ready
            .then(() => {
              animateThemeTransition();
            })
            .catch(() => {});

          transition.finished
            .catch(() => {})
            .finally(() => {
              cleanupThemeTransition(scrollX, scrollY);
            });
        } catch {
          setStoredTheme(nextTheme);
          cleanupThemeTransition(scrollX, scrollY);
        }
      });

      prefersDark.addEventListener("change", (event) => {
        if (window.localStorage.getItem("shellpp-site-theme")) {
          return;
        }
        applyTheme(event.matches ? "dark" : "light");
      });

      if (footerYear) {
        footerYear.textContent = `© ${new Date().getFullYear()} Shell++`;
      }
    </script>
  </body>
</html>
